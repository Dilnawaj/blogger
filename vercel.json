{
  "rewrites": [
    {
      "source": "/user/:path*",
      "destination": "http://blogger-backend.us-east-1.elasticbeanstalk.com/user/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "http://blogger-backend.us-east-1.elasticbeanstalk.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
